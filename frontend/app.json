{
  "expo": {
    "name": "ChefMate",
    "slug": "chefmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "chefmate",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D2520"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chefmate.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ChefMate uses your camera to scan food items for inventory management.",
        "NSPhotoLibraryUsageDescription": "ChefMate accesses your photo library to add food images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D2520"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chefmate.app",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "902c7d20-ad4d-4e9c-8cf3-5ec596ba624c"
      },
      "router": {}
    }
  }
}
